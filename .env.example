# === Stalcraft API (получить на developers.stalcraft.net через Telegram бот EXBO) ===
STALCRAFT_CLIENT_ID=your_client_id
STALCRAFT_CLIENT_SECRET=your_client_secret
STALCRAFT_API_MODE=production
STALCRAFT_REGION=RU

# === Database ===
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://stalcraft:change_me_strong_password@postgres:5432/stalcraft

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Auth (JWT) — сгенерируй: openssl rand -hex 32 ===
SECRET_KEY=change_me_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=SC_TRADING_auc_bot
TELEGRAM_WEBHOOK_URL=

# === RabbitMQ (брокер событий push) ===
# Прод: задать ОТДЕЛЬНОГО пользователя (не guest) — эти значения подставляются
# в docker-compose.prod.yml (RABBITMQ_DEFAULT_USER/PASS и RABBITMQ_URL воркера/
# push_service). Локально dev-compose использует встроенный guest/guest.
RABBITMQ_USER=sc_push
RABBITMQ_PASSWORD=change_me_strong_rabbitmq_password
# Используется backend/локально; в проде URL для сервисов собирается из USER/PASSWORD выше.
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# === Web Push (VAPID) ===
# Сгенерировать ключи (один раз, внутри backend-образа где стоит py-vapid):
#   docker compose run --rm backend vapid --gen                    # -> private_key.pem / public_key.pem
#   docker compose run --rm backend vapid --applicationServerKey   # -> "Application Server Key = <b64url>"
# VAPID_PUBLIC_KEY  = значение Application Server Key (base64url) — уходит в браузер.
VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY = приватный ключ для pywebpush: путь к private_key.pem ЛИБО
#   base64url raw-ключ. Только на сервере (backend + push_service). НЕ коммитить.
VAPID_PRIVATE_KEY=
# Контакт для push-сервисов браузеров (mailto: или https URL).
VAPID_SUBJECT=mailto:admin@sctrading.ru

# === App ===
DEBUG=false
# Укажи IP сервера или домен (без слеша в конце)
CORS_ORIGINS=http://161.104.44.231
# Окружение: production или stage (stage добавляет префикс [STAGE] в Telegram уведомления)
APP_ENV=production
