# === Stalcraft API (получить на developers.stalcraft.net через Telegram бот EXBO) ===
STALCRAFT_CLIENT_ID=your_client_id
STALCRAFT_CLIENT_SECRET=your_client_secret
STALCRAFT_API_MODE=production
STALCRAFT_REGION=RU

# === Database ===
POSTGRES_PASSWORD=stalcraft_dev
DATABASE_URL=postgresql+asyncpg://stalcraft:stalcraft_dev@postgres:5432/stalcraft

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Auth (JWT) — сгенерируй: openssl rand -hex 32 ===
SECRET_KEY=change_me_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# === Telegram Bot (заполнить позже) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# === App ===
DEBUG=true
CORS_ORIGINS=http://localhost:3000
