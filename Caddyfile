# Stalcraft Trading Assistant — Production Caddyfile
# Разместить: /etc/caddy/Caddyfile
# Перезапуск: docker exec caddytest-caddy-1 caddy reload --config /etc/caddy/Caddyfile --adapter caddyfile

sctrading.ru {
    # Backend API
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Swagger UI
    handle /docs* {
        reverse_proxy backend:8000
    }
    handle /openapi.json {
        reverse_proxy backend:8000
    }

    # Frontend SPA (React)
    handle {
        reverse_proxy frontend:80
    }
}
